# ---- Challenge data: NEVER commit the 100K pool (grader supplies it) ----
data/candidates.jsonl
data/*.jsonl
# The challenge bundle (brackets must be escaped — they are a gitignore glob class)
\[PUB\] India_runs_data_and_ai_challenge/
*India_runs_data_and_ai_challenge/
__MACOSX/
*.DS_Store
.DS_Store

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ipynb_checkpoints/
build/
dist/
.venv/
venv/
env/

# ---- Artifacts ----
# cand_emb.npy is ~77MB (< GitHub's 100MB limit) and IS committed so the rank
# step reproduces without a 69-min precompute. Checkpoints/logs are not.
artifacts/_emb_partial.npy
artifacts/_progress.json
artifacts/precompute.log
artifacts/*.tmp

# ---- Local scratch ----
scratch/
*.log
submission_dev.csv
eval/eda_report.json
# regenerable dev/eval artifact dirs (the committed one is artifacts/)
artifacts_dev/
artifacts_eval/

# deck preview scratch
deck/_preview/
