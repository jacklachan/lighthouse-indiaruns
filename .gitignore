__MACOSX/
*.DS_Store
.DS_Store

# ---- Python ----
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
.pytest_cache/
.ipynb_checkpoints/
build/
dist/
.venv/
venv/
env/

